generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  username      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  folders       Folder[]
  files         File[]
  vaultAssets   VaultAsset[]
}

model Folder {
  id              String   @id @default(cuid())
  userId          String
  parentFolderId  String?
  name            String
  transactionHash String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent          Folder?  @relation("FolderTree", fields: [parentFolderId], references: [id], onDelete: SetNull)
  children        Folder[] @relation("FolderTree")
  files           File[]

  @@index([userId])
  @@index([parentFolderId])
}

model File {
  id           String      @id @default(cuid())
  userId       String
  folderId     String?
  filename     String
  originalName String
  blobKey      String
  storageProvider StorageProvider @default(LOCAL)
  storageMetadata Json?
  size         Int
  mimeType     String
  isEncrypted  Boolean     @default(false)
  previewType  PreviewType
  status       FileStatus  @default(READY)
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder       Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  shares       Share[]
  views        FileView[]
  vaultFiles   VaultFile[]

  @@index([userId])
  @@index([folderId])
}

model Share {
  id           String    @id @default(cuid())
  fileId       String?
  vaultAssetId String?
  token        String    @unique
  shareType    ShareType
  passwordHash String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  file         File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  vaultAsset   VaultAsset? @relation(fields: [vaultAssetId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([vaultAssetId])
}

model FileView {
  id        String        @id @default(cuid())
  fileId    String
  viewerIp  String?
  userAgent String?
  eventType ViewEventType @default(VIEW)
  viewedAt  DateTime      @default(now())
  file      File          @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([eventType])
}

model VaultAsset {
  id                String            @id @default(cuid())
  userId            String
  nftObjectId       String
  collectionName    String?
  nftName           String?
  nftOwnerAddress   String?
  nftMetadataSnapshot Json?
  publicPreviewMode PublicPreviewMode @default(TEASER)
  ownerOnly         Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaultFiles        VaultFile[]
  accessLogs        VaultAccessLog[]
  shares            Share[]

  @@unique([userId, nftObjectId])
  @@index([userId])
}

model VaultFile {
  id             String        @id @default(cuid())
  vaultAssetId   String
  fileId         String
  role           VaultFileRole
  encryptedKeyRef String?
  createdAt      DateTime      @default(now())
  vaultAsset     VaultAsset    @relation(fields: [vaultAssetId], references: [id], onDelete: Cascade)
  file           File          @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([vaultAssetId])
  @@index([fileId])
  @@index([role])
}

model VaultAccessLog {
  id             String          @id @default(cuid())
  vaultAssetId   String
  accessorWallet String?
  accessType     VaultAccessType
  createdAt      DateTime        @default(now())
  vaultAsset     VaultAsset      @relation(fields: [vaultAssetId], references: [id], onDelete: Cascade)

  @@index([vaultAssetId])
  @@index([accessType])
}

enum FileStatus {
  READY
  PROCESSING
}

enum ShareType {
  PUBLIC
  PRIVATE
  PASSWORD
}

enum ViewEventType {
  VIEW
  DOWNLOAD
}

enum PreviewType {
  IMAGE
  VIDEO
  AUDIO
  PDF
  TEXT
  OTHER
}

enum PublicPreviewMode {
  HIDDEN
  BLURRED
  TEASER
  PLACEHOLDER
}

enum VaultFileRole {
  PRIMARY_MEDIA
  UNLOCKABLE
  ATTACHMENT
  TEASER
}

enum VaultAccessType {
  OWNER_VIEW
  SHARED_VIEW
  DOWNLOAD
  FAILED_CHECK
}

enum StorageProvider {
  LOCAL
  BLOB
  SHELBY
}
